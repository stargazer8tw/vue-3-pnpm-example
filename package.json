{
  "name": "vue-project",
  "version": "2.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "run-p type-check \"build-only {@}\" --",
    "preview": "vite preview",
    "build-only": "vite build",
    "type-check": "vue-tsc --build",
    "format": "prettier --write src/",
    "update-browserslist": "pnpm dlx update-browserslist-db@latest"
  },
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=10.0.0"
  },
  "prettier": {
    "$schema": "https://json.schemastore.org/prettierrc",
    "semi": false,
    "tabWidth": 2,
    "useTabs": false,
    "singleQuote": true,
    "printWidth": 100,
    "trailingComma": "es5"
  },
  "dependencies": {
    "pinia": "catalog:vue",
    "vue": "catalog:vue",
    "vue-i18n": "catalog:vue",
    "vue-router": "catalog:vue"
  },
  "peerDependencies": {
    "@unovis/ts": "catalog:shadcn-vue",
    "@unovis/vue": "catalog:shadcn-vue",
    "@vee-validate/zod": "catalog:shadcn-vue",
    "@vueuse/core": "catalog:shadcn-vue",
    "class-variance-authority": "catalog:shadcn-vue",
    "clsx": "catalog:shadcn-vue",
    "embla-carousel-vue": "catalog:shadcn-vue",
    "reka-ui": "catalog:shadcn-vue",
    "tailwind-merge": "catalog:css",
    "tw-animate-css": "catalog:css",
    "vaul-vue": "catalog:shadcn-vue",
    "vee-validate": "catalog:shadcn-vue",
    "vue-input-otp": "catalog:shadcn-vue",
    "vue-sonner": "catalog:shadcn-vue",
    "zod": "catalog:shadcn-vue"
  },
  "optionalDependencies": {
    "@formkit/auto-animate": "catalog:shadcn-vue-peer",
    "@internationalized/date": "catalog:shadcn-vue-peer",
    "@tanstack/vue-table": "catalog:shadcn-vue-peer"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "catalog:css",
    "@tailwindcss/vite": "catalog:css",
    "@tsconfig/node22": "catalog:vite",
    "@types/node": "catalog:vite",
    "@vitejs/plugin-vue": "catalog:vite",
    "@vue/tsconfig": "catalog:vite",
    "autoprefixer": "catalog:css",
    "lucide-vue-next": "catalog:icons",
    "npm-run-all2": "catalog:vite",
    "postcss": "catalog:css",
    "prettier": "catalog:vite",
    "tailwindcss": "catalog:css",
    "typescript": "catalog:vite",
    "unplugin-vue-components": "catalog:vite",
    "vite": "catalog:vite",
    "vite-plugin-vue-devtools": "catalog:vite",
    "vue-tsc": "catalog:vite"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@tailwindcss/oxide",
      "esbuild"
    ],
    "overrides": {
      "rollup@>=4.0.0 <4.59.0": ">=4.59.0",
      "picomatch@<2.3.2": ">=2.3.2",
      "picomatch@>=4.0.0 <4.0.4": ">=4.0.4",
      "yaml@>=1.0.0 <1.10.3": ">=1.10.3",
      "yaml@>=2.0.0 <2.8.3": ">=2.8.3",
      "lodash-es@>=4.0.0 <=4.17.23": ">=4.18.0",
      "lodash-es@<=4.17.23": ">=4.18.0",
      "defu@<=6.1.4": ">=6.1.5",
      "vite@>=7.0.0 <=7.3.1": ">=7.3.2",
      "vite@>=7.1.0 <=7.3.1": ">=7.3.2"
    }
  }
}
